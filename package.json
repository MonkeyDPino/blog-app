{
  "name": "@blog/root",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @blog/backend start:dev",
    "build:backend": "pnpm --filter @blog/backend build",
    "test": "pnpm --filter @blog/backend test",
    "test:e2e": "pnpm --filter @blog/backend test:e2e",
    "frontend:dev": "pnpm --filter @blog/frontend dev",
    "lint": "eslint \"apps/**/*.ts\" \"apps/**/*.tsx\" \"packages/**/*.ts\" --fix",
    "format": "prettier --write \"apps/**/*.ts\" \"apps/**/*.tsx\" \"packages/**/*.ts\"",
    "migration:run": "pnpm --filter @blog/backend migration:run"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
