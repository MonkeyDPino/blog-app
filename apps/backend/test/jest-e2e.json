{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@blog/types$": "<rootDir>/../../../packages/types/src/index.ts",
    "^@blog/types/(.*)$": "<rootDir>/../../../packages/types/src/$1"
  }
}
